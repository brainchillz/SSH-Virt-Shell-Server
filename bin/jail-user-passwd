#!/bin/bash
#
# jail-user-passwd — set or reset a jail user's login password.
#
# The password lives INSIDE the user's jail (sshpiper forwards the login
# password to the jail's sshd for validation), so this simply runs
# chpasswd there. Users can also change their own with plain 'passwd'.

set -euo pipefail
BASE_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "${BASE_DIR}/lib/common.sh"

usage() { echo "Usage: jail-user-passwd <username> [--password <password> | --password-stdin]" >&2; exit 1; }

username="${1:-}"
[ -n "${username}" ] || usage
shift
password=""
generated=true
while [ $# -gt 0 ]; do
    case "$1" in
        --password) password="${2:?--password needs a value}"; generated=false; shift 2 ;;
        # Read the new password from stdin so it never appears on the argv
        # (used by the self-service portal for a user-chosen password).
        --password-stdin) password="$(cat)"; generated=false; shift ;;
        *) usage ;;
    esac
done

need_root
validate_username "${username}"
jail="${JAIL_PREFIX}${username}"
container_exists "${jail}" || die "no such jail: ${jail}"
incus exec "${jail}" -- id -u "${username}" >/dev/null 2>&1 || die "no such user in ${jail}: ${username}"

if [ -z "${password}" ]; then
    ${generated} || die "empty password"
    password="$(gen_password)"
fi
printf '%s:%s\n' "${username}" "${password}" | incus exec "${jail}" -- chpasswd

log "Password updated for '${username}'"
# Only reveal a password we generated; a user/admin-chosen one is already
# known. (Must be an `if`, not `${generated} && echo`, or a false value
# would make the script exit non-zero on a user-chosen password.)
if ${generated}; then
    echo "  New password: ${password}"
fi
